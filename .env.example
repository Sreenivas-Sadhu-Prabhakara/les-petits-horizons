# Postgres (pgvector) — reuses the shared pgvector server on :5433, new `french` DB
DATABASE_URL=postgres://solar:solar@localhost:5433/french?sslmode=disable
DATABASE_URL_TEST=postgres://solar:solar@localhost:5433/french_test?sslmode=disable
# LiteLLM gateway (already running this machine)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=local
# Model names as registered in LiteLLM
EMBED_MODEL=bge-m3
GEN_MODEL=qwen-coder-32b
# Use the distilled SHORT persona (set true only when GEN_MODEL is the tuned LoRA model)
USE_SHORT_PROMPT=false
